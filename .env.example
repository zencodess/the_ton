# =============================================================================
# The Ton — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com → Project Settings → API)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# This is the service role key — only used server-side, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# -----------------------------------------------------------------------------
# OpenAI (https://platform.openai.com/api-keys)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# -----------------------------------------------------------------------------
# Twilio (https://console.twilio.com → Account Info)
# Note: Twilio is configured INSIDE Supabase Dashboard under
# Authentication → Phone Provider → Twilio.
# You only need these here if calling Twilio directly.
# -----------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
